generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  /// ADMIN | USER
  role         String    @default("USER")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  seedProfiles SeedProfile[]
  seedJobs     SeedJob[]
}

model Session {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  userId             String?
  user               User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// JSON array of module ids 0-7, e.g. [0,3,1,2,4,5,6,7]
  moduleOrder        String
  /// Index into moduleOrder for the active module
  modulePhaseIndex   Int       @default(0)
  /// LLM assistant turns in the current module (not counting canned opener)
  followUpsInModule  Int       @default(0)
  /// IN_PROGRESS | COMPLETED
  status             String    @default("IN_PROGRESS")
  /// AI 已输出 [[NEXT_MODULE]] 但等待用户下一条消息后再展示下一模块开场白
  pendingModuleAdvance Boolean @default(false)
  /// pending 分支已重试次数（LLM 在承接回应里仍违规问新问题时递增；满 2 次强制推进，防止死循环）
  pendingAdvanceAttempts Int   @default(0)
  /// 用户累计提交次数（每次点「提交回答」+1）
  totalUserTurns       Int     @default(0)
  /// 正在等待用户回复满意度反馈
  feedbackPending      Boolean @default(false)
  /// 满意度反馈已收集完成
  feedbackCollected    Boolean @default(false)
  messages           Message[]
  seedJobs           SeedJob[]

  @@index([userId])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  moduleId  Int
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model SeedProfile {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version            Int      @default(1)
  generatedAt        DateTime @default(now())
  basicInfo          Json
  soulSeed           Json
  eventsSeed         Json
  sourceSessionIds   Json
  sourceSessionCount Int      @default(1)

  @@index([userId])
  @@unique([userId, version])
}

model SeedJob {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId  String   @unique
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  /// PENDING | PROCESSING | COMPLETED | FAILED
  status     String   @default("PENDING")
  attempts   Int      @default(0)
  lastError  String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, status])
  @@index([createdAt])
}
