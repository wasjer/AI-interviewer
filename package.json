{
  "name": "ai-interviewer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3500",
    "dev:host": "next dev -H 0.0.0.0 -p 3500",
    "tunnel": "cloudflared tunnel --url http://127.0.0.1:3500",
    "build": "prisma generate && next build",
    "start": "next start",
