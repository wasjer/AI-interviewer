# 复制为 .env 后按需填写（勿把含密钥的 .env 提交到 Git）

DATABASE_URL="file:./prisma/dev.db"

# 登录会话加密密钥：至少 32 字符。生产环境必填。生成示例：openssl rand -base64 32
# 开发环境可不设，将使用内置占位密钥（切勿用于公网）
# SESSION_PASSWORD=

# 固定管理员账号（首次用该账号密码登录会自动创建 ADMIN）
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# HTTPS 部署时通常为 true；本地 http 调试可设 false
# COOKIE_SECURE=false

# 普通用户注册已默认关闭，由管理员在 /admin 创建账号

# MiniMax OpenAI 兼容 Chat
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.1
# MINIMAX_REASONING_SPLIT=false
